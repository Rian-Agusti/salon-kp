<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<FilesMatch "^\.env|composer\.json|composer\.lock|package\.json|package-lock\.json">
    Order allow,deny
    Deny from all
</FilesMatch>

<DirectoryMatch "^(vendor|storage|bootstrap/cache|tests)/">
    Order allow,deny
    Deny from all
</DirectoryMatch>
